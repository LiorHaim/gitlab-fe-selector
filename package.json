{
  "name": "gitlab-fe-selector",
  "version": "1.2.2",
  "description": "A RHDH 1.8 Frontend Plugin for selecting GitLab groups and repositories with owner access.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "rhdh-cli plugin export",
    "package": "rhdh-cli plugin package --export-to ./dist-pkg && cd dist-pkg/gitlab-fe-selector && npm pack && mv *.tgz ../..",
    "clean": "rm -rf dist dist-dynamic dist-pkg",
    "test": "jest"
  },
  "keywords": [
    "rhdh",
    "backstage",
    "plugin",
    "gitlab",
    "scaffolder-field-extension"
  ],
  "author": "",
  "license": "Apache-2.0",
  "backstage": {
    "role": "frontend-plugin"
  },
  "dependencies": {
    "@backstage/core-plugin-api": "^1.9.0",
    "@backstage/plugin-scaffolder-react": "^1.10.0",
    "@material-ui/core": "^4.12.4",
    "react-router-dom": "^6.3.0"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0"
  },
  "devDependencies": {
    "@red-hat-developer-hub/cli": "*",
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ]
}
