{
  "name": "gitlab-fe-selector",
  "version": "1.4.0",
  "description": "A RHDH 1.8 Frontend Plugin for selecting GitLab groups and repositories with owner access.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsc --build",
    "export-dynamic": "npx @red-hat-developer-hub/cli@latest plugin export",
    "package": "npm run build && npm run export-dynamic && npm pack ./dist-dynamic --pack-destination .",
    "clean": "rm -rf dist dist-dynamic dist-pkg",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix"
  },
  "keywords": [
    "rhdh",
    "backstage",
    "plugin",
    "gitlab",
    "scaffolder-field-extension"
  ],
  "author": "",
  "license": "Apache-2.0",
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "gitlab-fe-selector",
    "pluginPackages": [
      "gitlab-fe-selector"
    ]
  },
  "scalprum": {
    "name": "gitlab-fe-selector",
    "exposedModules": {
      "PluginRoot": "./src/index.ts"
    }
  },
  "peerDependencies": {
    "@backstage/core-plugin-api": "^1.9.0",
    "@backstage/plugin-scaffolder-react": "^1.10.0",
    "@material-ui/core": "^4.12.4",
    "@material-ui/lab": "^4.0.0-alpha.61",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-router-dom": "^6.3.0"
  },
  "devDependencies": {
    "@backstage/core-plugin-api": "^1.9.0",
    "@backstage/plugin-scaffolder-react": "^1.10.0",
    "@material-ui/core": "^4.12.4",
    "@material-ui/lab": "^4.0.0-alpha.61",
    "@red-hat-developer-hub/cli": "*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "@types/react": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.3.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "dist-dynamic"
  ]
}
